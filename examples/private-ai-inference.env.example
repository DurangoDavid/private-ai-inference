# =============================================================================
# private-ai-inference — watcher/provisioning env (copy to .env, edit, NEVER
# commit the real one). No secrets belong in this file in the repo — replace
# every placeholder. VAST_API_KEY lives ONLY on the CPU box.
#
# Copy:  cp examples/private-ai-inference.env.example .env   (.env is gitignored)
# =============================================================================

# Required by every Vast script: your Vast.ai API key
# (https://console.vast.ai/account/). Read from env only — NEVER logged, NEVER
# committed. Keep it on the CPU box (or your operator workstation), not in Git.
export VAST_API_KEY="replace-with-vast-api-key"

# Required by scripts/deploy.sh + scripts/setup-tunnel.sh: path to the SSH key
# registered with Vast.ai for `ssh_direct` access to your rented instances.
export PRIVATE_AI_SSH_KEY="$HOME/.ssh/vast_ed25519"

# --- Vast GPU watcher identity (how the CPU picks YOUR box from the account) ---
# The CPU watcher selects running instances whose label OR image_uuid contains
# this string. Terraform labels a freshly-provisioned box
# "<VAST_INSTANCE_LABEL>-01" (TF_VAR_deployment_name), so this matches it.
export VAST_INSTANCE_LABEL="private-ai-gpu"

# Safety default: 0 = only explicitly-tagged boxes are selected (recommended).
# Set 1 to grab the account's single running GPU when you haven't tagged it
# (e.g. a hand-rented box). The watcher will then pick any running instance.
export VAST_INSTANCE_MATCH_ANY=0

# --- CPU watcher loop (private-ai repo's watch-vast-gpu.sh; mirrored here for
#     operators who run the public one-shot scripts) ---
# Poll interval, seconds (30-60 recommended).
export VAST_WATCH_INTERVAL_SECONDS=45
# Host path to the SSH key the CPU uses to reach the GPU (mounted into the
# tunnel container). /root/.ssh/vast_ed25519 on the CPU VM (root-managed).
export GPU_TUNNEL_KEY="/root/.ssh/vast_ed25519"
# Default customer slug (the app container to validate after a reconnect).
export GPU_DEFAULT_CUSTOMER="david"
# The Ollama API port on the GPU box (loopback). Always 11434.
export GPU_OLLAMA_INTERNAL_PORT=11434

# Optional Vast API base URL (default https://console.vast.ai).
# export VAST_API_URL="https://console.vast.ai"

# Optional: delegate model loading to an external "GPU gateway" repo cloned onto
# the box after boot (e.g. it pulls the models + runs install.sh). When
# PRIVATE_AI_GPU_REPO is set, the box onstart serves Ollama empty and deploy.sh
# deploys this repo instead of pulling models itself. If that repo is PRIVATE,
# also point PRIVATE_AI_GPU_DEPLOY_KEY at a read-only GitHub deploy key (PRIVATE
# half shipped to the box at runtime — NEVER commit it).
# export PRIVATE_AI_GPU_REPO="https://github.com/DurangoDavid/private-ai-gpu.git"
# export PRIVATE_AI_GPU_REPO_CMD="./install.sh"
# export PRIVATE_AI_GPU_DEPLOY_KEY="$HOME/.ssh/private-ai-gpu_deploy_ed25519"
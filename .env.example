# Required: your Vast.ai API key (https://console.vast.ai/account/).
export VAST_API_KEY="replace-with-vast-api-key"

# Required by scripts/deploy.sh + scripts/setup-tunnel.sh: path to the SSH key
# registered with Vast.ai for `ssh_direct` access to your rented instances.
export PRIVATE_AI_SSH_KEY="$HOME/.ssh/vast_ed25519"

# Optional: delegate model loading to an external "GPU gateway" repo that is
# cloned onto the box after boot and run (e.g. it pulls the models + runs
# install.sh). When PRIVATE_AI_GPU_REPO is set, the box onstart serves Ollama
# empty and deploy.sh deploys this repo instead of pulling models itself.
#
# If that repo is PRIVATE (private-ai-gpu currently is), you also need a
# read-only GitHub deploy key: generate one with `scripts/new-deploy-key.sh`,
# paste its PUBLIC half into the repo's Settings → Deploy keys, and point
# PRIVATE_AI_GPU_DEPLOY_KEY at the PRIVATE half. The private key is shipped to
# the box at runtime over SSH — NEVER commit it to this repo.
# export PRIVATE_AI_GPU_REPO="https://github.com/DurangoDavid/private-ai-gpu.git"
# export PRIVATE_AI_GPU_REPO_CMD="./install.sh"
# export PRIVATE_AI_GPU_DEPLOY_KEY="$HOME/.ssh/private-ai-gpu_deploy_ed25519"